# Auto-generated by postino config fix. Do not edit by hand.
# To activate, add this line once to your dovecot.conf:
#     !include {{ ctx.input.dovecot_dir }}/dovecot-postino.conf
# identity_backend = {{ ctx.input.identity_backend.value }}

passdb {
  driver = sql
  args = {{ ctx.input.dovecot_dir }}/dovecot-sql.conf.ext
{%- if ctx.input.identity_backend.value == "hybrid" %}
  result_success = return-ok
  result_failure = continue
  result_internalfail = continue
{%- elif ctx.input.identity_backend.value == "noauth" %}
  result_success = continue-ok
  result_failure = continue
  result_internalfail = continue
{%- endif %}
}

userdb {
  driver = sql
  args = {{ ctx.input.dovecot_dir }}/dovecot-sql.conf.ext
}

service lmtp {
  unix_listener {{ ctx.input.lmtp_socket }} {
    mode = 0600
    user = postfix
    group = postfix
  }
}

protocol lmtp {
  postmaster_address = postmaster@localhost
  mail_plugins = $mail_plugins quota sieve
}
