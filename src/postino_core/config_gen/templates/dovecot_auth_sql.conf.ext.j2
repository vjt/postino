# Auto-generated by postino. identity_backend={{ ctx.input.identity_backend.value }}.
passdb {
  driver = sql
  args = {{ ctx.input.dovecot_dir }}/dovecot-sql.conf.ext
{% if ctx.input.identity_backend.value == "hybrid" %}
  result_success = return-ok
  result_failure = continue
  result_internalfail = continue
{% elif ctx.input.identity_backend.value == "noauth" %}
  result_success = continue-ok
  result_failure = continue
  result_internalfail = continue
{% endif %}
}

userdb {
  driver = sql
  args = {{ ctx.input.dovecot_dir }}/dovecot-sql.conf.ext
}
{% if ctx.input.identity_backend.value != "local" %}

# identity_backend={{ ctx.input.identity_backend.value }} — chain a non-SQL
# passdb here (LDAP, PAM, OIDC, ...). postino does NOT emit that block.
# `postino check` will refuse if no chained passdb is present.
{% endif %}
