# postino-managed: domain existence (excludes alias_domain targets)
hosts = {{ ctx.db_host }}
user = {{ ctx.db_user }}
password = {{ ctx.db_password.get_secret_value() }}
dbname = {{ ctx.db_name }}
query = SELECT domain FROM domain WHERE domain='%s' AND active = '1' AND NOT EXISTS (SELECT 1 FROM alias_domain WHERE alias_domain.alias_domain = domain.domain)
