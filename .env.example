# Copy to .env and fill in. .env is gitignored.

# Required for `./scripts/check.sh` to run integration tests against a real
# DB instead of skipping. Set up the schema once with:
#   sudo mariadb -e "CREATE DATABASE postino_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
#   sudo mariadb -e "CREATE USER 'postino_test'@'localhost' IDENTIFIED BY 'postino_test_dev';"
#   sudo mariadb -e "GRANT ALL ON postino_test.* TO 'postino_test'@'localhost'; FLUSH PRIVILEGES;"
POSTINO_TEST_DB_URL=mysql+pymysql://postino_test:postino_test_dev@localhost/postino_test

# Required only for `twine upload dist/*` (release).
# Generate at https://pypi.org/manage/account/token/ scoped to il-postino.
PYPI_TOKEN=pypi-...
