{
  "name": "il-postino",
  "version": "@VERSION@",
  "origin": "mail/il-postino",
  "comment": "typed Python CLI + daemon for PostfixAdmin-schema mail servers",
  "maintainer": "vjt@openssl.it",
  "www": "https://github.com/vjt/postino",
  "abi": "FreeBSD:14:amd64",
  "arch": "freebsd:14:x86:64",
  "prefix": "/usr/local",
  "licenselogic": "single",
  "licenses": ["MIT"],
  "deps": {
    "python311": {"origin": "lang/python311", "version": "3.11.0"},
    "mlmmj": {"origin": "mail/mlmmj", "version": "1.3.0"}
  },
  "desc": "il-postino administers domains, mailboxes, aliases, alias-domains, and mlmmj mailing lists on a Postfix + Dovecot stack using the PostfixAdmin SQL schema.\n\nShipped: postino(1) CLI and postinod(8) daemon. The whole Python venv is bundled in /usr/local/share/postino/venv so pkg install does not need internet."
}
