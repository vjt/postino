{
  "name": "il-postino",
  "version": "@VERSION@",
  "origin": "mail/il-postino",
  "comment": "typed Python CLI + daemon for PostfixAdmin-schema mail servers",
  "maintainer": "vjt@openssl.it",
  "www": "https://github.com/vjt/postino",
  "abi": "FreeBSD:14:amd64",
  "arch": "freebsd:14:x86:64",
  "prefix": "/usr/local",
  "licenselogic": "single",
  "licenses": ["MIT"],
  "deps": {
    "python311":              {"origin": "lang/python311",            "version": "3.11.0"},
    "py311-pydantic":         {"origin": "devel/py-pydantic@py311",   "version": "2.7.0"},
    "py311-pydantic-settings":{"origin": "devel/py-pydantic-settings@py311", "version": "2.3.0"},
    "py311-bcrypt":           {"origin": "security/py-bcrypt@py311",  "version": "4.0.0"},
    "py311-cryptography":     {"origin": "security/py-cryptography@py311", "version": "42.0.0"},
    "py311-passlib":          {"origin": "security/py-passlib@py311", "version": "1.7.0"},
    "py311-typer":            {"origin": "devel/py-typer@py311",      "version": "0.12.0"},
    "py311-rich":             {"origin": "devel/py-rich@py311",       "version": "13.7.0"},
    "py311-sqlalchemy20":     {"origin": "databases/py-sqlalchemy20@py311", "version": "2.0.0"},
    "py311-pymysql":          {"origin": "databases/py-pymysql@py311","version": "1.1.0"},
    "mlmmj":                  {"origin": "mail/mlmmj",                "version": "1.3.0"}
  },
  "desc": "il-postino administers domains, mailboxes, aliases, alias-domains, and mlmmj mailing lists on a Postfix + Dovecot stack using the PostfixAdmin SQL schema.\n\nShipped: postino(1) CLI and postinod(8) daemon. C-extension dependencies (pydantic-core, bcrypt, cryptography) come from FreeBSD ports; pure-Python deps (litestar, scim2-models, etc.) are bundled in the venv at /usr/local/share/postino/venv."
}
