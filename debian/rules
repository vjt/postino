#!/usr/bin/make -f
export DH_VIRTUALENV_INSTALL_ROOT=/usr/share

# Skip the python-virtualenv addon: on bookworm/trixie it ships a custom
# build/binary sequence that silently drops dh_installman and excludes
# dh_installsystemd, dh_installtmpfiles, etc. We use the default dh
# sequence and call dh_virtualenv from override_dh_auto_install so
# dh_installman + dh_installsystemd run normally on the standard helpers.
%:
	dh $@

override_dh_auto_install:
	dh_virtualenv \
	  --python /usr/bin/python3 \
	  --install-suffix postino/venv \
	  --builtin-venv \
	  --requirements debian/requirements-deb.txt \
	  --extra-pip-arg --no-cache-dir \
	  --extra-pip-arg --upgrade-strategy=only-if-needed

# Bundled venv ships its own ELFs; the default dh_strip/dh_shlibdeps/dh_dwz
# helpers don't have anything useful to do on .so files inside the venv
# and slow the build down.
override_dh_strip:
override_dh_shlibdeps:
override_dh_dwz:
