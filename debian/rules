#!/usr/bin/make -f
export DH_VIRTUALENV_INSTALL_ROOT=/usr/share

# Use the dh-virtualenv addon (inserts dh_virtualenv into the normal dh
# sequence) rather than the python-virtualenv addon (which REPLACES the
# sequence and excludes dh_installsystemd / dh_installman runtime install
# of debian/<pkg>.<unit>.service + debian/<pkg>.manpages).
%:
	dh $@ --with dh-virtualenv

override_dh_virtualenv:
	dh_virtualenv \
	  --python /usr/bin/python3 \
	  --install-suffix postino/venv \
	  --builtin-venv \
	  --requirements debian/requirements-deb.txt \
	  --extra-pip-arg --no-cache-dir \
	  --extra-pip-arg --upgrade-strategy=only-if-needed
