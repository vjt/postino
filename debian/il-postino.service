[Unit]
Description=postino daemon (SCIM + Zitadel sink)
After=network.target mariadb.service
Wants=mariadb.service

[Service]
Type=simple
User=postinod
Group=postinod
EnvironmentFile=-/etc/postino/postinod.env
ExecStart=/usr/bin/postinod
Restart=on-failure
RestartSec=5
ProtectSystem=strict
ReadWritePaths=/var/spool/mlmmj /var/mail
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
